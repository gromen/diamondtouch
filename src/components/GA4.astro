---
// GA4 via Google Tag Manager.
// - Loads GTM only in production builds (import.meta.env.PROD)
// - Respects consent via the CookieBar (default consent = denied; granted on accept)
// - Skips on localhost even if PROD is true (e.g. local `astro build && preview`)
import { site } from '~/lib/site';

const gtmId = site.gtmId;
const enabled = import.meta.env.PROD && !!gtmId;
---

{enabled && (
  <>
    <script is:inline>
      (function () {
        // Block on localhost/127.* to avoid polluting analytics during local testing.
        const host = location.hostname;
        if (host.includes('localhost') || host.includes('127.0.0.1') || host.endsWith('.local')) {
          window.__GTM_DISABLED__ = true;
          return;
        }
        // Default consent: denied until user accepts in CookieBar.
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          wait_for_update: 500,
        });
      })();
    </script>
    <script is:inline define:vars={{ gtmId }}>
      (function (w, d, s, l, i) {
        if (w.__GTM_DISABLED__) return;
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', gtmId);
    </script>
  </>
)}
