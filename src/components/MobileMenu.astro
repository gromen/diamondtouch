---
import { site } from '~/lib/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div id="mobile-menu" class="mobile-menu md:hidden" aria-hidden="true">
  <nav aria-label="Menu mobilne" class="container-page py-6 flex flex-col">
    {site.nav.map((item) => {
      const active = item.href === '/' ? path === '/' : path.startsWith(item.href);
      return (
        <a
          href={item.href}
          aria-current={active ? 'page' : undefined}
          class:list={['mobile-menu-link', active && 'is-active']}
        >
          <svg class="mobile-menu-link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" />
          </svg>
          <span class="mobile-menu-link-text">{item.label}</span>
        </a>
      );
    })}
  </nav>
</div>

<style is:global>
  .nav-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    transition: background-color 200ms ease, border-color 200ms ease;

    &:hover {
      background-color: var(--color-bg-elevated);
    }
  }

  .nav-burger-line {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background-color: currentColor;
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .header-open .nav-burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .header-open .nav-burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .header-open .nav-burger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    border-top: 1px solid transparent;
    transition:
      max-height 480ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease,
      border-color 260ms ease;
  }

  .header-open .mobile-menu {
    max-height: 80vh;
    opacity: 1;
    border-top-color: var(--color-border);
  }

  .mobile-menu-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 0.25rem;
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-fg-muted);
    opacity: 0;
    transform: translateY(14px);
    transition:
      color 260ms ease,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 340ms ease;
  }

  .mobile-menu-link + .mobile-menu-link {
    border-top: 1px solid var(--color-border);
  }

  .mobile-menu-link:hover,
  .mobile-menu-link:focus-visible,
  .mobile-menu-link.is-active {
    color: var(--color-fg);
  }

  .mobile-menu-link:hover .mobile-menu-link-text,
  .mobile-menu-link:focus-visible .mobile-menu-link-text,
  .mobile-menu-link.is-active .mobile-menu-link-text {
    transform: translateX(4px);
  }

  .mobile-menu-link:hover .mobile-menu-link-icon,
  .mobile-menu-link:focus-visible .mobile-menu-link-icon,
  .mobile-menu-link.is-active .mobile-menu-link-icon {
    opacity: 1;
    transform: scale(1) rotate(45deg);
    color: color-mix(in oklab, var(--color-brand-300) 85%, white);
    filter: drop-shadow(
      0 0 6px color-mix(in oklab, var(--color-brand-300) 55%, transparent)
    );
  }

  :where(.light) .mobile-menu-link:hover .mobile-menu-link-icon,
  :where(.light) .mobile-menu-link:focus-visible .mobile-menu-link-icon,
  :where(.light) .mobile-menu-link.is-active .mobile-menu-link-icon {
    color: color-mix(in oklab, var(--color-brand-700) 85%, black);
    filter: drop-shadow(
      0 0 4px color-mix(in oklab, var(--color-brand-500) 45%, transparent)
    );
  }

  .header-open .mobile-menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  .header-open .mobile-menu-link:nth-child(1) { transition-delay: 120ms; }
  .header-open .mobile-menu-link:nth-child(2) { transition-delay: 180ms; }
  .header-open .mobile-menu-link:nth-child(3) { transition-delay: 240ms; }
  .header-open .mobile-menu-link:nth-child(4) { transition-delay: 300ms; }
  .header-open .mobile-menu-link:nth-child(5) { transition-delay: 360ms; }

  .mobile-menu-link-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-brand-400);
    opacity: 0;
    transform: scale(0.3) rotate(0deg);
    transition:
      opacity 360ms ease,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      color 260ms ease,
      filter 260ms ease;
  }

  .mobile-menu-link-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-burger-line,
    .mobile-menu,
    .mobile-menu-link,
    .mobile-menu-link-icon,
    .mobile-menu-link-text {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!header || !btn || !menu) return;

    function setOpen(open) {
      header.classList.toggle('header-open', open);
      btn.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
    }

    btn.addEventListener('click', () => {
      setOpen(!header.classList.contains('header-open'));
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    const mq = window.matchMedia('(min-width: 768px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  })();
</script>
