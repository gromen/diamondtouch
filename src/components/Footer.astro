---
import SocialLinks from "~/components/SocialLinks.astro";
import { site } from "~/lib/site";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border py-10 text-sm text-fg-muted">
  <div class="container-page grid gap-6 md:grid-cols-3">
    <div>
      <p class="font-display text-fg text-lg">{site.name}</p>
      <p class="mt-2">{site.contact.hours}</p>
      <SocialLinks class="mt-4" showHandle />
    </div>
    <div>
      <p>{site.map.address}</p>
      <p>
        <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`}
          >{site.contact.phone}</a
        >
      </p>
    </div>
    <div class="md:text-right">
      <p>© {year} {site.name}</p>
      <p>
        <a href="/polityka-prywatnosci">Polityka prywatności</a>
      </p>
    </div>
  </div>
  <p class="mt-3 flex items-center gap-1.5 justify-center \">
    <svg
      class="w-3.5 h-3.5 shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path
        d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
      ></path>
    </svg>
    realizacja:&nbsp;<a
      href="https://gromek.dev"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-brand-400 transition-colors">Marcin Gromek</a
    >
  </p>
</footer>
