---
import { site } from '~/lib/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--color-border)] py-10 text-sm text-[var(--color-fg-muted)]">
  <div class="container-page grid gap-6 md:grid-cols-3">
    <div>
      <p class="font-display text-[var(--color-fg)] text-lg">{site.name}</p>
      <p class="mt-2">{site.contact.hours}</p>
    </div>
    <div>
      <p>{site.map.address}</p>
      <p><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
      <p><a href={`tel:${site.contact.phone.replace(/\s/g, '')}`}>{site.contact.phone}</a></p>
    </div>
    <div class="md:text-right">
      <p>© {year} {site.name}</p>
      <p>
        <a href="/polityka-prywatnosci">Polityka prywatności</a>
      </p>
    </div>
  </div>
</footer>
