---
import { Image } from 'astro:assets';
import logo from '~/assets/logo/logo.jpeg';
import { site } from '~/lib/site';
import ThemeToggle from '~/components/ThemeToggle.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  id="site-header"
  class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-bg)_80%,transparent)] border-b border-border"
>
  <div class="container-page flex items-center justify-between py-3">
    <a href="/" class="flex items-center gap-3" aria-label={`${site.name} — strona główna`}>
      <Image src={logo} alt={site.name} width={40} height={40} class="rounded-full object-cover" />
      <span class="font-display text-lg tracking-wide hidden sm:block">{site.name}</span>
    </a>

    <nav aria-label="Główna nawigacja" class="hidden md:flex items-center gap-1 md:gap-2">
      {site.nav.map((item) => {
        const active = item.href === '/' ? path === '/' : path.startsWith(item.href);
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'px-3 py-2 rounded-full text-sm transition-colors',
              active ? 'text-brand-400' : 'text-fg-muted hover:text-fg',
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <ThemeToggle />
    </nav>

    <div class="flex md:hidden items-center gap-2">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        class="nav-burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-burger-line"></span>
        <span class="nav-burger-line"></span>
        <span class="nav-burger-line"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu md:hidden" aria-hidden="true">
    <nav aria-label="Menu mobilne" class="container-page py-6 flex flex-col">
      {site.nav.map((item) => {
        const active = item.href === '/' ? path === '/' : path.startsWith(item.href);
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            class:list={['mobile-menu-link', active && 'is-active']}
          >
            <svg class="mobile-menu-link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" />
            </svg>
            <span class="mobile-menu-link-text">{item.label}</span>
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .nav-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    transition: background-color 200ms ease, border-color 200ms ease;

    &:hover {
      background-color: var(--color-bg-elevated);
    }
  }

  .nav-burger-line {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background-color: currentColor;
    border-radius: 2px;
    transform-origin: center;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  :global(.header-open) .nav-burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  :global(.header-open) .nav-burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  :global(.header-open) .nav-burger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    border-top: 1px solid transparent;
    transition: max-height 480ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease,
      border-color 260ms ease;
  }

  :global(.header-open) .mobile-menu {
    max-height: 80vh;
    opacity: 1;
    border-top-color: var(--color-border);
  }

  .mobile-menu-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 0.25rem;
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-fg-muted);
    opacity: 0;
    transform: translateY(14px);
    transition: color 260ms ease,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 340ms ease;

    & + & {
      border-top: 1px solid var(--color-border);
    }

    &:hover,
    &:focus-visible,
    &.is-active {
      color: var(--color-fg);
    }

    &:hover .mobile-menu-link-text,
    &:focus-visible .mobile-menu-link-text,
    &.is-active .mobile-menu-link-text {
      transform: translateX(4px);
    }

    &:hover .mobile-menu-link-icon,
    &:focus-visible .mobile-menu-link-icon,
    &.is-active .mobile-menu-link-icon {
      opacity: 1;
      transform: scale(1) rotate(45deg);
      color: color-mix(in oklab, var(--color-brand-300) 85%, white);
      filter: drop-shadow(
        0 0 6px color-mix(in oklab, var(--color-brand-300) 55%, transparent)
      );
    }
  }

  :where(.light) .mobile-menu-link {
    &:hover .mobile-menu-link-icon,
    &:focus-visible .mobile-menu-link-icon,
    &.is-active .mobile-menu-link-icon {
      color: color-mix(in oklab, var(--color-brand-700) 85%, black);
      filter: drop-shadow(
        0 0 4px color-mix(in oklab, var(--color-brand-500) 45%, transparent)
      );
    }
  }

  :global(.header-open) .mobile-menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.header-open) .mobile-menu-link:nth-child(1) { transition-delay: 120ms, 120ms, 120ms; }
  :global(.header-open) .mobile-menu-link:nth-child(2) { transition-delay: 180ms, 180ms, 180ms; }
  :global(.header-open) .mobile-menu-link:nth-child(3) { transition-delay: 240ms, 240ms, 240ms; }
  :global(.header-open) .mobile-menu-link:nth-child(4) { transition-delay: 300ms, 300ms, 300ms; }
  :global(.header-open) .mobile-menu-link:nth-child(5) { transition-delay: 360ms, 360ms, 360ms; }

  .mobile-menu-link-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-brand-400);
    opacity: 0;
    transform: scale(0.3) rotate(0deg);
    transition: opacity 360ms ease,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      color 260ms ease,
      filter 260ms ease;
  }

  .mobile-menu-link-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-burger-line,
    .mobile-menu,
    .mobile-menu-link,
    .mobile-menu-link-icon,
    .mobile-menu-link-text {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!header || !btn || !menu) return;

    function setOpen(open) {
      header.classList.toggle('header-open', open);
      btn.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
    }

    btn.addEventListener('click', () => {
      setOpen(!header.classList.contains('header-open'));
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    const mq = window.matchMedia('(min-width: 768px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  })();
</script>
