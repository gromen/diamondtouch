---
import { site } from '~/lib/site';

interface Props {
  class?: string;
  showHandle?: boolean;
}

const { class: className = '', showHandle = false } = Astro.props;
---

<ul class:list={['flex flex-col gap-2', className]}>
  {site.social.map((item) => (
    <li>
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${item.name} — ${item.handle}`}
        class="inline-flex items-center gap-2 hover:text-fg transition-colors"
      >
        {item.name === 'Instagram' && (
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        )}
        {item.name === 'TikTok' && (
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16.5 3h-3v12.2a2.8 2.8 0 1 1-2.8-2.8c.3 0 .6 0 .8.1V9.4a6 6 0 1 0 5 5.9V8.8a7 7 0 0 0 4 1.3V7a4 4 0 0 1-4-4z" />
          </svg>
        )}
        <span>{showHandle ? item.handle : item.name}</span>
      </a>
    </li>
  ))}
</ul>
