---
import Layout from "~/layouts/Layout.astro";

const services = [
  {
    title: "Konsultacja & projekt",
    description:
      "Indywidualne podejście, analiza potrzeb i dobór najlepszych rozwiązań.",
    price: "",
  },
  {
    title: "Realizacja podstawowa",
    description: "Kompleksowa realizacja zgodnie z ustalonym projektem.",
    price: "",
  },
  {
    title: "Realizacja premium",
    description:
      "Rozszerzony zakres, dodatkowe detale, dłuższa gwarancja efektu.",
    price: "",
  },
  {
    title: "Pakiet abonamentowy",
    description: "Regularne wizyty w stałej, atrakcyjnej cenie.",
    price: "",
  },
];
---

<Layout
  title="Usługi"
  description="Zakres usług Diamond Touch Studio wraz z orientacyjnym cennikiem."
>
  <section class="container-page pt-12 pb-16 md:pt-16">
    <header class="max-w-2xl">
      <p
        class="text-[var(--color-brand-400)] uppercase tracking-[0.2em] text-xs"
      >
        Oferta
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-display">Usługi</h1>
      <p class="mt-4 text-[var(--color-fg-muted)]">
        Poniżej znajdziesz zakres naszych usług. Ostateczna cena zawsze ustalana
        jest po konsultacji i zależy od specyfiki realizacji.
      </p>
    </header>

    <ul class="mt-10 grid gap-4 md:grid-cols-2">
      {
        services.map((s) => (
          <li class="group rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 transition-colors hover:border-[var(--color-brand-500)]">
            <div class="flex items-start justify-between gap-4">
              <h2 class="text-xl font-display">{s.title}</h2>
              <span class="shrink-0 text-sm text-[var(--color-brand-400)]">
                {s.price}
              </span>
            </div>
            <p class="mt-3 text-[var(--color-fg-muted)]">{s.description}</p>
          </li>
        ))
      }
    </ul>

    <div class="mt-12">
      <a href="/kontakt" class="btn btn-primary">Umów konsultację</a>
    </div>
  </section>
</Layout>
