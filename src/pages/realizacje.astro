---
import { Image } from 'astro:assets';
import Layout from '~/layouts/Layout.astro';

// Eagerly glob all portfolio images so Astro can optimize them at build time.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '~/assets/portfolio/*.{jpeg,jpg,png,webp,avif}',
  { eager: true }
);

const images = Object.entries(modules)
  .map(([path, mod]) => ({ path, src: mod.default }))
  .sort((a, b) => a.path.localeCompare(b.path, undefined, { numeric: true }));
---

<Layout title="Realizacje" description="Galeria zrealizowanych prac Diamond Touch Studio.">
  <section class="container-page pt-12 pb-16">
    <header class="max-w-2xl">
      <p class="text-brand-400 uppercase tracking-[0.2em] text-xs">Portfolio</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-display">Realizacje</h1>
      <p class="mt-4 text-fg-muted">
        Wybór prac, które najlepiej oddają nasz styl. Każda realizacja to autorski projekt
        dopasowany do klienta.
      </p>
    </header>

    <div class="mt-10 grid gap-3 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {images.map(({ src }, i) => (
        <figure class="group relative overflow-hidden rounded-2xl bg-elevated-bg">
          <Image
            src={src}
            alt={`Realizacja ${i + 1}`}
            widths={[320, 480, 768]}
            sizes="(min-width: 1024px) 22vw, (min-width: 768px) 30vw, 45vw"
            loading={i < 4 ? 'eager' : 'lazy'}
            class="aspect-4/5 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
        </figure>
      ))}
    </div>
  </section>
</Layout>
