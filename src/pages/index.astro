---
import { Image } from "astro:assets";
import hero from "~/assets/portfolio/work-1.jpeg";
import work3 from "~/assets/portfolio/work-10.jpeg";
import work2 from "~/assets/portfolio/work-5.jpeg";
import Layout from "~/layouts/Layout.astro";
import { site } from "~/lib/site";
---

<Layout
  title="Detailing Samochodowy Ostrów Mazowiecka"
  description="Diamond Touch Studio — przyciemnianie szyb, folia kameleon i detailing wnętrza w Ostrowi Mazowieckiej. Profesjonalne oklejanie folią, PPF, dechroming. Umów wizytę."
>
  <section class="container-page pt-12 pb-16 md:pt-20 md:pb-24">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="text-brand-400 uppercase tracking-[0.2em] text-xs">
          Studio · Ostrów Mazowiecka
        </p>
        <div class="relative mt-3 inline-block">
          <h1
            class="text-4xl md:text-6xl font-display leading-[1.05] shiny-text"
          >
            {site.name}
          </h1>

          <svg
            class="sparkle w-4 h-4 -top-2 -left-3 md:w-5 md:h-5"
            style="animation-delay: 0s"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z"
            ></path>
          </svg>
          <svg
            class="sparkle w-3 h-3 top-2 right-7 lg:right-18 md:w-4 md:h-4"
            style="animation-delay: 0.6s"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z"
            ></path>
          </svg>
          <svg
            class="sparkle w-5 h-5 top-1/2 left-1/3 md:w-6 md:h-6"
            style="animation-delay: 1.2s"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z"
            ></path>
          </svg>
          <svg
            class="sparkle w-2.5 h-2.5 top-1 left-1/2 md:w-3 md:h-3"
            style="animation-delay: 1.8s"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z"
            ></path>
          </svg>
          <svg
            class="sparkle w-3 h-3 -bottom-2 lg:bottom-10 right-1/4 md:w-4 md:h-4"
            style="animation-delay: 2.2s"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z"
            ></path>
          </svg>
        </div>

        <p class="mt-5 text-fg-muted text-lg max-w-prose">
          Precyzja, estetyka i detal. Tworzymy realizacje, które mówią za siebie
          — zobacz portfolio i umów się na wizytę.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/realizacje" class="btn btn-primary">Zobacz realizacje</a>
          <a href="/kontakt" class="btn">Kontakt</a>
        </div>
      </div>
      <div class="relative aspect-4/5 md:aspect-3/4">
        <Image
          src={hero}
          alt="Realizacja studia"
          widths={[480, 768, 1024]}
          sizes="(min-width: 768px) 40vw, 100vw"
          class="absolute inset-0 h-full w-full object-cover rounded-3xl"
        />
      </div>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="flex items-end justify-between mb-6">
      <h2 class="text-2xl md:text-3xl">Wybrane realizacje</h2>
      <a href="/realizacje" class="text-sm text-fg-muted hover:text-fg"
        >Wszystkie →</a
      >
    </div>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      {
        [hero, work2, work3].map((img, i) => (
          <figure class="overflow-hidden rounded-2xl">
            <Image
              src={img}
              alt={`Realizacja ${i + 1}`}
              widths={[320, 640, 960]}
              sizes="(min-width: 768px) 30vw, 90vw"
              class="h-full w-full object-cover aspect-square hover:scale-[1.02] transition-transform duration-500"
            />
          </figure>
        ))
      }
    </div>
  </section>
</Layout>
