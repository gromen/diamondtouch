---
import GoogleMap from '~/components/GoogleMap.astro';
import SocialLinks from '~/components/SocialLinks.astro';
import Layout from '~/layouts/Layout.astro';
import { site } from '~/lib/site';
---

<Layout title="Kontakt" description="Skontaktuj się z Diamond Touch Studio — telefon, e-mail i lokalizacja na mapie.">
  <section class="container-page pt-12 pb-16">
    <header class="max-w-2xl">
      <p class="text-brand-400 uppercase tracking-[0.2em] text-xs">Kontakt</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-display">Zapraszamy do studia</h1>
      <p class="mt-4 text-fg-muted">
        Najszybszy kontakt to telefon lub zgłoszenie przez Instagram. Odpowiadamy tego samego dnia roboczego.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <div class="space-y-6">
        <div class="rounded-2xl border border-border bg-elevated p-6">
          <h2 class="text-lg font-display">Dane kontaktowe</h2>
          <dl class="mt-4 grid gap-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-fg-muted">Telefon</dt>
              <dd><a href={`tel:${site.contact.phone.replace(/\s/g, '')}`}>{site.contact.phone}</a></dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-fg-muted">Adres</dt>
              <dd class="text-right">{site.map.address}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-fg-muted">Godziny</dt>
              <dd class="text-right">{site.contact.hours}</dd>
            </div>
          </dl>
          <div class="mt-6 flex flex-wrap gap-2">
            <a href={`tel:${site.contact.phone.replace(/\s/g, '')}`} class="btn btn-primary">Zadzwoń</a>
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-elevated p-6">
          <h2 class="text-lg font-display">Social media</h2>
          <SocialLinks class="mt-4 text-sm" showHandle />
        </div>
      </div>

      <GoogleMap />
    </div>
  </section>
</Layout>
