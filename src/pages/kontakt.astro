---
import Layout from '~/layouts/Layout.astro';
import GoogleMap from '~/components/GoogleMap.astro';
import { site } from '~/lib/site';
---

<Layout title="Kontakt" description="Skontaktuj się z Diamond Touch Studio — telefon, e-mail i lokalizacja na mapie.">
  <section class="container-page pt-12 pb-16">
    <header class="max-w-2xl">
      <p class="text-[var(--color-brand-400)] uppercase tracking-[0.2em] text-xs">Kontakt</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-display">Zapraszamy do studia</h1>
      <p class="mt-4 text-[var(--color-fg-muted)]">
        Najszybszy kontakt to telefon lub e-mail. Odpowiadamy tego samego dnia roboczego.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <div class="space-y-6">
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <h2 class="text-lg font-display">Dane kontaktowe</h2>
          <dl class="mt-4 grid gap-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-[var(--color-fg-muted)]">Telefon</dt>
              <dd><a href={`tel:${site.contact.phone.replace(/\s/g, '')}`}>{site.contact.phone}</a></dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[var(--color-fg-muted)]">E-mail</dt>
              <dd><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[var(--color-fg-muted)]">Adres</dt>
              <dd class="text-right">{site.map.address}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[var(--color-fg-muted)]">Godziny</dt>
              <dd class="text-right">{site.contact.hours}</dd>
            </div>
          </dl>
          <div class="mt-6 flex flex-wrap gap-2">
            <a href={`tel:${site.contact.phone.replace(/\s/g, '')}`} class="btn btn-primary">Zadzwoń</a>
            <a href={`mailto:${site.contact.email}`} class="btn">Napisz e-mail</a>
          </div>
        </div>
      </div>

      <GoogleMap />
    </div>
  </section>
</Layout>
